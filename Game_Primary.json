{
  "name": "Primary",
  "menuBackgroundImage": "https://sygmax637.github.io/TCG-PRIMARY/Dos%20Primary.jpg",
  "defaultRessources": {
    "backgrounds": [
      "https://sygmax637.github.io/TCG-PRIMARY/Illu%20Tapis%20IA.jpg"
    ],
    "decksUrl": "https://sygmax637.github.io/TCG-PRIMARY/Primary%20Starter%20Deck.json"
  },
  "customHelp": "Au début de la partie : répartissez vos sorts entre Deck CAC et Deck DIST, puis mélangez les deux decks. À chaque tour, choisissez un deck et piochez 1 carte.",
  "cardRotation": 45,
  "cards": {
    "dataUrl": "https://sygmax637.github.io/TCG-PRIMARY/CardListPrimarySet1.json",
    "cardBack": "https://sygmax637.github.io/TCG-PRIMARY/Dos%20Primary.jpg"
  },
  "deckBuilding": {
    "mainFilters": ["Type", "Name", "Cost"],
    "formats": [
      {
        "title": "Classic",
        "gameplay": "Classic",
        "deckRuleset": "Standard"
      }
    ],
    "deckRulesets": {
      "Standard": {
        "general": {
          "min": 46,
          "maxPerCard": 3
        }
      }
    },
  "gameplay": {
    "Classic": {
      "mulligan": {
        "info": "Remplacez les cartes de votre choix puis repiochez jusqu'à 7.",
        "startingHandSize": 7,
        "drawNewSelectedCards": true
      },
      "newTurn": {
        "drawOnStart": false,
        "sharedTurn": false
      },
      "beforeGameStart": {
        "initialBoardSetup": [
          {
            "action": "moveByCategory",
            "category": "Créature càc",
            "destination": "Deck CAC"
          },
          {
            "action": "moveByCategory",
            "category": "Créature dist",
            "destination": "Deck DIST"
          },
          {
            "action": "moveByCategory",
            "category": "Sort",
            "destination": "Sorts"
          }
        ]
      },
      "countersStartingValues": [20, 0],
      "hideFacedDownCards": false,
      "sections": {
        "customSections": ["Ligne càc", "Ligne dist", "Mana", "Mage", "Deck CAC", "Deck DIST", "Sorts"],
        "layout": {
          "direction": "column",
          "content": [
            { "section": "Ligne càc" },
            {
              "direction": "row",
              "content": [
                { "section": "Deck DIST", "style": { "width": "25%" } },
                { "section": "Ligne dist", "style": { "width": "50%" } },
                { "section": "Deck CAC", "style": { "width": "25%" } }
              ]
            },
            {
              "direction": "row",
              "content": [
                { "section": "Sorts" },
                { "section": "Mana" },
                { "section": "Mage" }
              ]
            }
          ]
        },
        "categoriesAlreadyOnBoard": ["Mage"],
        "autoPlayFromHand": {
          "Créature càc": "Ligne càc",
          "Créature dist": "Ligne dist",
          "Sort": "Ligne càc"
        },
        "autoPlayFromStack": {
          "Sort": "Discard"
        },
        "sectionsDict": {
          "Deck CAC": {
            "title": "Deck CAC",
            "isDeck": true,
            "alignment": "DECK",
            "quickActions": [
              {
                "action": "draw",
                "count": 1,
                "to": "Hand",
                "label": "Piocher CAC"
              }
            ]
          },
          "Deck DIST": {
            "title": "Deck DIST",
            "isDeck": true,
            "alignment": "DECK",
            "quickActions": [
              {
                "action": "draw",
                "count": 1,
                "to": "Hand",
                "label": "Piocher DIST"
              }
            ]
          },
          "Sorts": {
            "title": "Zone des Sorts (à répartir)",
            "alignment": "CENTER",
            "height": "SMALL"
          },
          "Mage": {
            "title": "Mage",
            "height": "MEDIUM",
            "alignment": "CENTER"
          },
          "Ligne dist": {
            "title": "Ligne distance",
            "alignment": "CENTER"
          },
          "Ligne càc": {
            "title": "Ligne corps à corps",
            "alignment": "CENTER"
          },
          "Mana": {
            "title": "Mana",
            "alignment": "START"
          }
        }
      }
          }
    }
  }
